aloha-example(
  :code-html="codeHtml"
  :code-js="codeJs"
  header="Retrieve invalid entries"
  description="Loads radio options from local JSON files and renders missing selected values inside a separate invalid entries group."
  :props="['url', 'url-retrieve']"
)
  a-radio(
    v-model="model1"
    key-id="id"
    key-label="label"
    label="Radio with retrieve"
    :url="url"
    :url-retrieve="urlRetrieve"
  )
  div model1: {{ model1 }}
